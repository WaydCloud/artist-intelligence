# 데이터 접근 API 키 목록 (예시 파일 — 실제 값은 여기 넣지 말 것)
# 실제 키는 OS 환경변수로 설정하세요:  setx FIRECRAWL_API_KEY "fc-..."  (설정 후 VSCode 재시작)
# .mcp.json 이 ${FIRECRAWL_API_KEY} 로 이 환경변수를 참조합니다.

# Firecrawl — 발급: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxx

# YouTube Data API v3 (댓글=센티먼트 1순위 앵커) — GCP 콘솔에서 발급:
#   console.cloud.google.com → 프로젝트 생성 → "YouTube Data API v3" 사용 설정 → 사용자 인증 정보 → API 키
#   쿼터 기본 10,000 units/day. commentThreads.list ~1 unit, search.list=100(회피). 강한 캐싱 권장.
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxx

# Apify (소셜 폭 최대 — IG/TikTok/X/Reddit; 매니지드 스크래퍼 = 리스크 이전 2차 레일, D-002/§4)
#   발급: https://console.apify.com/settings/integrations  (Personal API token, "apify_api_..." 형식)
#   설정:  setx APIFY_TOKEN "apify_api_xxxx"   (설정 후 MCP 사용하려면 VSCode 재시작)
#   .mcp.json 이 https://mcp.apify.com 에 Bearer 로 이 값을 전달합니다.
#   ⚠ 종량제(예 IG ~$1.5/1K) · ToS 책임 사용자 귀속 · 공개(로그아웃) 데이터만 · 지표만 적재·PII 제거(§4).
#   검증:  python scripts/apify_probe.py            # 무료 — 토큰·플랜만 확인
#          python scripts/apify_probe.py --run apify~instagram-scraper --input-file <in.json> --max-items 5
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxx

# Bright Data (차단 강한 소스·대량 백필 — PIPA/GDPR 법무검토 후, 마지막 레일)
# BRIGHTDATA_API_TOKEN=
